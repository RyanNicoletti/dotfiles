filetype off

call plug#begin()
Plug 'neoclide/coc.nvim', {'branch': 'release'}

call plug#end()

syntax on

filetype plugin indent on

let mapleader=","

set number
set ruler
set noerrorbells
set encoding=utf-8
set ttyfast
set splitright
set splitbelow
set wrap
set textwidth=79
set tabstop=2
set smarttab
set shiftwidth=2
set smartindent
set autoindent
set hlsearch
set showmode
set incsearch
set relativenumber
